ext":", "},{"type":"codeVoice","code":"hasTag(...)"},{"type":"text","text":", "},{"type":"codeVoice","code":"addTag(...)"},{"type":"text","text":", "},{"type":"codeVoice","code":"removeTag(...)"},{"type":"text","text":", "},{"type":"codeVoice","code":"toggleTag(...)"},{"type":"text","text":" etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Collections that contain "},{"type":"reference","isActive":true,"identifier":"doc:\/\/TagKit\/documentation\/TagKit\/Taggable"},{"type":"text","text":" types also get some additional functionality as well."}]},{"anchor":"Views","level":2,"type":"heading","text":"Views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"TagKit also has a few views that aim at making it easier to work with tags. For instance, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/TagKit\/documentation\/TagKit\/TagList"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/TagKit\/documentation\/TagKit\/TagEditList"},{"type":"text","text":" let you list and edit tags with a customizable tag view, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/TagKit\/documentation\/TagKit\/TagCapsule"},{"type":"text","text":" renders tags with a customizable style and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/TagKit\/documentation\/TagKit\/TagTextField"},{"type":"text","text":" automatically slugifies text as you type."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can have a look at the SwiftUI previews in these files to see them in action."}]}]}],"schemaVersion":{"major":0,"minor":2,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/tagkit\/getting-started"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/TagKit\/documentation\/TagKit\/Getting-Started","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This article describes how you get started with TagKit."}],"kind":"article","metadata":{"r